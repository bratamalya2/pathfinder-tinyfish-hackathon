# PathFinder Environment Variables (Sample Template)
# Copy this file to .env and fill in your actual credentials.

# API Server Configuration
PORT=4000

# Set to 'false' to use real TinyFish + OpenAI APIs instead of mock responses
USE_MOCKS=true

# Neo4j Database Credentials (AuraDB)
# Get these from your Neo4j / AuraDB instance
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# TinyFish Agent API
# Required by AgentService to scrape curriculum paths
TINYFISH_API_KEY=your_tinyfish_api_key_here

# OpenAI / Anthropic API
# Used by SynthesisService for structured course nodes
OPENAI_API_KEY=your_openai_api_key_here

# Frontend Configuration (Vite)
# The URL where your backend API is accessible
VITE_API_BASE_URL=http://localhost:4000/api
